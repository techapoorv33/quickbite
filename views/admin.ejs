<!DOCTYPE html>
<html>
<head>
    <title>Admin Panel - QuickBite</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<div class="navbar">
    <div><strong>QuickBite Admin ⚙️</strong></div>
    <div>
        <a href="/dashboard">Dashboard</a>
        <a href="/logout">Logout</a>
    </div>
</div>

<div class="container">

    <h1>Admin Panel</h1>

    <div class="card">
        <h2>Add Menu Item</h2>

        <form action="/add-menu" method="POST">
            <input name="name" placeholder="Name" required>
            <input name="description" placeholder="Description" required>
            <input name="price" type="number" placeholder="Price" required>
            <input name="category" placeholder="Category" required>
            <input name="rating" type="number" step="0.1" min="1" max="5" placeholder="Rating (1-5)" value="4.5">
            <input name="imageUrl" placeholder="Image URL (optional)">
            <button class="btn btn-primary">Add Item</button>
        </form>
    </div>

    <div class="card">
        <h2>All Menu Items</h2>

        <% menuItems.forEach(item => { %>
            <div style="margin-bottom:16px; padding-bottom:14px; border-bottom:1px solid rgba(15,23,42,0.08);">
                <div style="display:flex; gap:14px; align-items:center; flex-wrap:wrap;">
                    <div>
                        <strong><%= item.name %></strong> - ₹<%= item.price %>
                        <div style="color:#666; margin-top:6px;">
                            ⭐ <%= item.rating %>/5
                        </div>
                        <% if(item.imageUrl){ %>
                            <div style="margin-top:8px;">
                                <img src="<%= item.imageUrl %>" alt="<%= item.name %>" style="width:64px; height:64px; border-radius:12px; object-fit:cover; border:1px solid rgba(15,23,42,0.08);">
                            </div>
                        <% } %>
                    </div>

                    <form action="/admin/update-menu" method="POST" style="display:flex; gap:8px; align-items:center; flex-wrap:wrap;">
                        <input type="hidden" name="id" value="<%= item._id %>">
                        <input type="number" name="rating" step="0.1" min="1" max="5" placeholder="Rating" value="<%= item.rating %>" style="width:140px;">
                        <input type="text" name="imageUrl" placeholder="Image URL" value="<%= item.imageUrl || '' %>" style="width:260px;">
                        <button class="btn btn-secondary">Update</button>
                    </form>

                    <form action="/delete-menu" method="POST" style="display:inline;">
                        <input type="hidden" name="id" value="<%= item._id %>">
                        <button class="btn btn-danger">Delete</button>
                    </form>
                </div>
            </div>
        <% }) %>
    </div>

    <div class="card">
        <h2>All Users</h2>

        <% users.forEach(user => { %>
            <form action="/admin/update-user" method="POST" style="margin-bottom:8px; display:flex; gap:8px; align-items:center;">
                <input type="hidden" name="id" value="<%= user._id %>">
                <span style="flex:1;"><strong><%= user.name %></strong> (<%= user.email %>)</span>
                <select name="role" style="padding:4px 8px;">
                    <option value="student" <%= user.role === "student" ? "selected" : "" %>>Student</option>
                    <option value="staff" <%= user.role === "staff" ? "selected" : "" %>>Staff</option>
                    <option value="admin" <%= user.role === "admin" ? "selected" : "" %>>Admin</option>
                </select>
                <button class="btn btn-secondary">Update</button>
            </form>
        <% }) %>
    </div>

    <div class="card">
    <h2>Coupon Management 🎟️</h2>

    <!-- Add Coupon Form -->
    <form action="/add-coupon" method="POST" style="margin-bottom:20px;">
        <input type="text" name="code" placeholder="Coupon Code" required>
        <input type="number" name="discount" placeholder="Discount %" required>
        <button class="btn btn-primary">Create Coupon</button>
    </form>

    <!-- List Coupons -->
    <% if(coupons.length === 0){ %>
        <p>No coupons created.</p>
    <% } else { %>

        <% coupons.forEach(coupon => { %>

            <div style="margin-bottom:10px;">
                <strong><%= coupon.code %></strong>
                - <%= coupon.discount %>% 
                - <%= coupon.active ? "Active" : "Inactive" %>

                <form action="/delete-coupon" method="POST" style="display:inline;">
                    <input type="hidden" name="id" value="<%= coupon._id %>">
                    <button class="btn btn-danger">Delete</button>
                </form>
            </div>

        <% }) %>

    <% } %>

    </div>

    <div class="card">
        <h2>Recent Feedback ⭐</h2>

        <% if(!feedbacks || feedbacks.length === 0){ %>
            <p>No feedback submitted yet.</p>
        <% } else { %>
            <% feedbacks.forEach(fb => { %>
                <div style="margin-bottom:10px; border-bottom:1px solid #eee; padding-bottom:8px;">
                    <p>
                        <strong>User:</strong>
                        <%= fb.userId ? fb.userId.name : "Unknown" %>
                        |
                        <strong>Order:</strong>
                        <%= fb.orderId ? fb.orderId._id.toString().slice(-5) : "N/A" %>
                    </p>
                    <p><strong>Rating:</strong> <%= fb.rating %>/5</p>
                    <% if(fb.comment){ %>
                        <p><strong>Comment:</strong> <%= fb.comment %></p>
                    <% } %>
                </div>
            <% }) %>
        <% } %>
    </div>

</div>

</body>
</html>