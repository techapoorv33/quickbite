<!DOCTYPE html>
<html>
<head>
    <title>Order Confirmed - QuickBite</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<div style="display:flex; justify-content:center; align-items:center; min-height:100vh; background:linear-gradient(135deg,#22c55e,#16a34a);">

    <div style="background:white; padding:50px; border-radius:20px; width:500px; text-align:center; box-shadow:0 20px 50px rgba(0,0,0,0.25);">

        <h1 style="color:#16a34a; margin-bottom:10px;">🎉 Order Confirmed!</h1>
        <p style="color:gray; margin-bottom:30px;">Your delicious food is being prepared.</p>

        <div style="text-align:left; margin-bottom:20px;">
            <p><strong>Order ID:</strong> <%= order._id %></p>
            <p><strong>Total Amount:</strong> ₹<%= order.totalAmount %></p>
            <p><strong>Pickup Time:</strong> <%= order.pickupTime %></p>

            <p>
                <strong>Status:</strong> 
                <span style="color:orange; font-weight:600;">
                    <%= order.status %>
                </span>
            </p>
        </div>

        <hr style="margin:20px 0;">

        <h3>Scan QR at Pickup Counter</h3>

        <div style="margin:20px 0;">
            <img src="<%= qrImage %>" width="200">
        </div>

        <div style="margin-top:30px;">
            <a href="/orders">
                <button class="btn btn-secondary">View My Orders</button>
            </a>

            <a href="/dashboard">
                <button class="btn btn-primary">Back to Dashboard</button>
            </a>
        </div>

    </div>

</div>

</body>
</html>