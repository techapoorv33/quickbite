<!DOCTYPE html>
<html>
<head>
    <title>Order Confirmed - QuickBite</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<div class="center-screen bg-gradient-success">

    <div class="modal-card">

        <h1 style="color: var(--success-600);">🎉 Order Confirmed!</h1>
        <p class="muted" style="margin-bottom: 18px;">Your delicious food is being prepared.</p>

        <div style="text-align:left; display:grid; gap:8px; margin-bottom:18px;">
            <p><strong>Order ID:</strong> <%= order._id %></p>
            <p><strong>Total Amount:</strong> ₹<%= order.totalAmount %></p>
            <p><strong>Pickup Time:</strong> <%= order.pickupTime %></p>
            <p>
                <strong>Status:</strong>
                <span class="status
                    <%= order.status === 'Pending' ? 'status-pending' :
                        order.status === 'Preparing' ? 'status-preparing' :
                        order.status === 'Ready' ? 'status-ready' :
                        'status-completed' %>">
                    <%= order.status %>
                </span>
            </p>
        </div>

        <hr style="margin: 16px 0;">

        <h3>Scan QR at Pickup Counter</h3>

        <div style="margin: 16px 0; display:flex; justify-content:center;">
            <img src="<%= qrImage %>" width="200" alt="Order QR Code">
        </div>

        <div style="margin-top: 16px; display:flex; gap:10px; flex-wrap:wrap;">
            <a href="/orders" class="btn btn-secondary">View My Orders</a>
            <a href="/feedback/<%= order._id %>" class="btn btn-primary">Rate This Order</a>
        </div>

    </div>

</div>

</body>
</html>