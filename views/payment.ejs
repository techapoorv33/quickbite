<!DOCTYPE html>
<html>
<head>
    <title>Payment - QuickBite</title>
    <link rel="stylesheet" href="/style.css">
    <script>
    function showPaymentOption() {
        const method = document.querySelector('input[name="method"]:checked').value;

        const cardSection = document.getElementById("card-section");
        const upiSection = document.getElementById("upi-section");

        const cardInputs = cardSection.querySelectorAll("input");
        const upiInputs = upiSection.querySelectorAll("input");

        // Hide all
        cardSection.style.display = "none";
        upiSection.style.display = "none";

        // Remove required from all
        cardInputs.forEach(input => input.removeAttribute("required"));
        upiInputs.forEach(input => input.removeAttribute("required"));

        if (method === "card") {
            cardSection.style.display = "block";
            cardInputs.forEach(input => input.setAttribute("required", true));
        }

        if (method === "upi") {
            upiSection.style.display = "block";
            upiInputs.forEach(input => input.setAttribute("required", true));
        }
    }

    window.onload = showPaymentOption;
</script>
</head>
<body>

<div class="center-screen bg-gradient-purple">

    <div class="modal-card">

        <h2 style="text-align:center;">💳 Payment Gateway</h2>
        <p class="muted" style="text-align:center; margin:10px 0 18px;">
            Total Amount: <strong style="color: var(--text);">₹<%= total %></strong>
        </p>

        <form action="/process-payment" method="POST">

            <h3>Select Payment Method</h3>

            <label style="display:flex; align-items:center; gap:10px;">
                <input type="radio" name="method" value="card" checked onchange="showPaymentOption()">
                Credit/Debit Card
            </label>

            <label style="display:flex; align-items:center; gap:10px;">
                <input type="radio" name="method" value="upi" onchange="showPaymentOption()">
                UPI
            </label>

            <label style="display:flex; align-items:center; gap:10px;">
                <input type="radio" name="method" value="cash" onchange="showPaymentOption()">
                Cash on Pickup
            </label>

            <!-- Card Section -->
            <div id="card-section" style="margin-top:10px;">
                <input type="text" placeholder="Card Number">
                <input type="text" placeholder="Expiry (MM/YY)">
                <input type="text" placeholder="CVV">
            </div>

            <!-- UPI Section -->
            <div id="upi-section" style="margin-top:10px; display:none;">
                <input type="text" placeholder="Enter UPI ID">
            </div>

            <button class="btn btn-primary full" style="margin-top:6px;">
                Confirm Payment
            </button>

        </form>

    </div>

</div>

</body>
</html>