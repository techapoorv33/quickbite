<!DOCTYPE html>
<html>
<head>
    <title>Add Item</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<div class="auth-container">
    <div class="auth-card">

        <h2>Add New Menu Item</h2>

        <form action="/admin/add-item" method="POST">

            <label>Name</label>
            <input type="text" name="name" required>

            <label>Description</label>
            <input type="text" name="description" required>

            <label>Price</label>
            <input type="number" name="price" required>

            <label>Emoji</label>
            <input type="text" name="emoji">

            <label>Rating (1-5)</label>
            <input type="number" step="0.1" min="1" max="5" name="rating" value="4.5">

            <label>Image URL (optional)</label>
            <input type="text" name="imageUrl" placeholder="Paste image URL">

            <label>Category</label>
            <select name="category" required>
                <option>Burgers</option>
                <option>Wraps</option>
                <option>South Indian</option>
                <option>Rice</option>
                <option>Snacks</option>
                <option>Beverages</option>
                <option>North Indian</option>
                <option>Italian</option>
            </select>

            <button class="btn btn-primary full">Add Item</button>

        </form>

    </div>
</div>

</body>
</html>