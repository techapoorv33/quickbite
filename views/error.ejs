<!DOCTYPE html>
<html>
<head>
    <title>Error - QuickBite</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<div style="display:flex; height:100vh; justify-content:center; align-items:center; background:linear-gradient(135deg,#ff7a18,#ffb347);">

    <div style="background:white; padding:40px; border-radius:15px; width:400px; text-align:center; box-shadow:0 15px 40px rgba(0,0,0,0.2);">

        <h2 style="color:#ef4444;">⚠️ Oops!</h2>

        <p style="font-size:18px; margin:20px 0;">
            <%= message %>
        </p>

        <a href="<%= backLink %>">
            <button class="btn btn-primary">Go Back</button>
        </a>

    </div>

</div>

</body>
</html>