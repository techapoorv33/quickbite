<!DOCTYPE html>
<html>
<head>
    <title>Error - QuickBite</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<div class="center-screen bg-gradient-orange">

    <div class="modal-card" style="text-align:center;">

        <h2 style="color: var(--danger-600);">⚠️ Oops!</h2>

        <p style="font-size: 16px; margin: 14px 0 18px; color: rgba(15, 23, 42, 0.85);">
            <%= message %>
        </p>

        <a class="btn btn-primary" href="<%= backLink %>">Go Back</a>

    </div>

</div>

</body>
</html>