<!DOCTYPE html>
<html>
<head>
    <title>Login - QuickBite</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body class="auth-body">

<nav class="navbar">
    <div class="logo">Quick<span>Bite</span></div>
    <div>
        <a href="/login">Log in</a>
        <a href="/register" class="btn btn-primary small">Sign up</a>
    </div>
</nav>

<div class="auth-container">

    <div class="auth-card">
        <div class="auth-icon">🍱</div>

        <h2>Welcome back</h2>
        <p class="auth-sub">Sign in to your QuickBite account</p>

        <form action="/login" method="POST">

            <label>Email</label>
            <input type="email" name="email" placeholder="you@college.edu" required>

            <label>Password</label>
            <input type="password" name="password" placeholder="••••••••" required>

            <button class="btn btn-primary full">Sign in</button>

        </form>

        <p class="auth-switch">
            Don't have an account? <a href="/register">Sign up</a>
        </p>

        <div class="demo-box">
            <strong>Demo accounts:</strong><br><br>
            Student: student@quickbite.com<br>
            Staff: staff@quickbite.com<br>
            Admin: admin@quickbite.com<br>
            Password: password
        </div>

    </div>

</div>

</body>
</html>