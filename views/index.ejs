<!DOCTYPE html>
<html>
<head>
    <title>QuickBite</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<!-- NAVBAR -->
<nav class="navbar">
    <div class="logo">Quick<span>Bite</span></div>
    <div>
        <a href="/login">Log in</a>
        <a href="/register" class="btn btn-primary">Sign up</a>
    </div>
</nav>

<!-- HERO SECTION -->
<section class="hero">
    <div class="hero-content">
        <div class="badge">● Now live on campus</div>
        <h1>
            Skip the line,<br>
            <span>grab your bite.</span>
        </h1>
        <p>
            Pre-order from your campus canteen, pay online,
            and collect with a QR code. No waiting, no hassle.
        </p>

        <div class="hero-buttons">
            <a href="/register" class="btn btn-primary">Get Started →</a>
            <a href="/menu" class="btn btn-outline">View Menu</a>
        </div>
    </div>
</section>

<!-- HOW IT WORKS -->
<section class="how">
    <h2>How it works</h2>
    <p class="sub">Four simple steps to your meal</p>

    <div class="grid">
        <div class="card">
            <h3>Step 1</h3>
            <h4>Browse Menu</h4>
            <p>Explore a wide variety of campus food options</p>
        </div>

        <div class="card">
            <h3>Step 2</h3>
            <h4>Pick Time Slot</h4>
            <p>Choose your preferred pickup time, skip the queue</p>
        </div>

        <div class="card">
            <h3>Step 3</h3>
            <h4>Quick Payment</h4>
            <p>Pay securely online in seconds</p>
        </div>

        <div class="card">
            <h3>Step 4</h3>
            <h4>QR Token</h4>
            <p>Scan your QR and collect instantly</p>
        </div>
    </div>
</section>

<!-- STATS -->
<section class="stats">
    <div>
        <h2>2,500+</h2>
        <p>Orders served</p>
    </div>
    <div>
        <h2>&lt; 30s</h2>
        <p>Avg. checkout time</p>
    </div>
    <div>
        <h2>4.8★</h2>
        <p>Student rating</p>
    </div>
</section>

<!-- CTA -->
<section class="cta">
    <h2>Ready to order?</h2>
    <p>Join thousands of students already using QuickBite</p>
    <a href="/register" class="btn btn-primary large">Create Free Account</a>
</section>

</body>
</html>